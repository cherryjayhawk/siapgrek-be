# --- MQTT ---
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=orchid_device
MQTT_PASSWORD=Orchid2026
MQTT_TOPIC=orchid/+/telemetry

# --- TimescaleDB ---
DATABASE_URL=postgresql://orchid_admin:orchid_secret_change_me@timescaledb:5432/orchid_db

# --- Redis (BullMQ) ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- Buffer Configuration ---
BATCH_INTERVAL_MS=300000
BUFFER_MAX_SIZE=50000
