// ===========================================
// Greenhouse Orchid IoT System - Core Schema
// ===========================================
// This schema defines the relational tables for:
// - Authentication (Better Auth: user, session)
// - AI Domain Tracking (disease_log)
// - Timeseries telemetry (managed via custom migrations/Timescale)
// - Command audit log (fuzzy logic actuator commands)

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// -------------------------------------------
// Authentication (Better Auth)
// -------------------------------------------

model User {
  id            String    @id @default(uuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  @@map("user")
}

model Session {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model Account {
  id                    String    @id @default(uuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("account")
}

model Verification {
  id         String   @id @default(uuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// -------------------------------------------
// AI & Intelligent Context
// -------------------------------------------

model DiseaseLog {
  id              String   @id @default(uuid())
  timestamp       DateTime @default(now())
  deviceId        String?  @default("node01") @map("device_id")

  fileName        String   @map("file_name")
  imageReference  String   @map("image_reference")

  diseaseName     String   @map("disease_name")
  classIndex      Int      @map("class_index")
  confidenceScore Float    @map("confidence_score")

  probBercakDaun  Float    @map("prob_bercak_daun")
  probBusukDaun   Float    @map("prob_busuk_daun")
  probSehat       Float    @map("prob_sehat")

  @@map("disease_log")
}

model EnvTelemetry {
  time              DateTime @db.Timestamptz
  deviceId          String   @default("node01") @map("device_id")
  envTemperature    Float?   @map("env_temperature")
  envHumidity       Float?   @map("env_humidity")
  lightLux          Int?     @map("light_lux")

  @@id([deviceId, time])
  @@map("env_telemetry")
}

model SoilTelemetry {
  time              DateTime @db.Timestamptz
  deviceId          String   @default("node01") @map("device_id")
  slaveId           String   @map("slave_id")
  soilTemperature   Float?   @map("soil_temperature")
  soilHumidity      Float?   @map("soil_humidity")
  soilPh            Float?   @map("soil_ph")
  soilConductivity  Float?   @map("soil_conductivity")

  @@id([deviceId, slaveId, time])
  @@map("soil_telemetry")
}

// -------------------------------------------
// Command Audit Log
// -------------------------------------------

model CommandLog {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  deviceId     String   @map("device_id")
  actuator     String
  commandValue Int      @map("command_value")
  source       String   @default("fuzzy-logic")

  @@map("command_log")
}

// -------------------------------------------
// Insight Audit Log
// -------------------------------------------

model InsightLog {
  id             String   @id @default(uuid())
  timestamp      DateTime @default(now())
  userQuery      String   @map("user_query")
  systemResponse String   @map("system_response")
  inputTokens    Int      @map("input_tokens")
  outputTokens   Int      @map("output_tokens")
  toolsCalled    Json?    @map("tools_called")

  @@map("insight_log")
}
